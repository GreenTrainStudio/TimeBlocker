{
  "manifest_version": 3,
  "name": "Time Saver",
  "version": "1.0",
  "description": "Blocks selected websites during specified time ranges and days of the week",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Blocking settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
